/*
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    sarek-wes-training — nextflow.config
    STaiMIC WES practical
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

nextflow.enable.dsl = 2

params {
    // Input / output
    input               = "${launchDir}/data/samplesheet.csv"
    outdir              = "${launchDir}/results"

    // Sarek's own minimal CI test genome — NOT full GRCh38.
    // A few MB downloaded from GitHub, not gigabytes from S3.
    // Same genome Sarek's own automated tests use every release.
    genome              = 'testdata.nf-core.sarek'
    igenomes_base       = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'

    // Tools: Strelka only for the live run.
    // VEP is shown via examples/annotated_example.vcf instead.
    tools               = 'strelka'
    split_fastq         = 0
    trim_fastq          = false
    skip_tools          = 'baserecalibrator'
    wes                 = true
}

// Resource ceiling — conservative for Codespaces free tier (2-core/8GB)
process {
    resourceLimits = [
        cpus   : 2,
        memory : '8.GB',
        time   : '30.min'
    ]
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 1
}

profiles {
    docker {
        docker.enabled       = true
        docker.runOptions    = '-u $(id -u):$(id -g)'
        singularity.enabled  = false
        conda.enabled        = false
    }
    conda {
        conda.enabled        = true
        docker.enabled       = false
        singularity.enabled  = false
    }
}

timeline {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

manifest {
    name            = 'sarek-wes-training'
    description     = 'WES variant analysis with Sarek - STaiMIC practical'
    version         = '1.1.0'
    nextflowVersion = '>=25.10.0'
    defaultBranch   = 'main'
}