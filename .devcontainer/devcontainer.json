{
  "name": "Sarek WES Training",
  "image": "mcr.microsoft.com/devcontainers/miniconda:latest",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },
  "postCreateCommand": "bash .devcontainer/post-install.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "nextflow.nextflow"
      ]
    }
  },
  "remoteUser": "root"
}
